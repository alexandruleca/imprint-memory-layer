#!/bin/bash
# Runs once, as root, at the end of `imprint-darwin-<arch>.pkg` installation.
#
# Responsibilities (kept deliberately lightweight):
#   1. Strip the quarantine xattr so the unsigned .app opens from Launchpad
#      without the "damaged and can't be opened" dialog.
#   2. chmod +x the launcher + binaries (imprint + bundled uv).
#   3. Symlink /usr/local/bin/imprint for CLI access.
#
# Everything else — profile choice, uv-provisioned venv, wheel install,
# `imprint setup`, sentinel write — now happens on first .app launch via
# Imprint-launcher + Terminal.app (see imprint-launcher script). This lets
# the Installer UI close promptly and gives the user a visible progress
# window for the (potentially several-minute) Python + wheel download.
set -eu

APP="/Applications/Imprint.app"
IMPRINT_HOME="$APP/Contents/Resources/imprint"

/usr/bin/xattr -cr "$APP" 2>/dev/null || true

chmod +x "$APP/Contents/MacOS/imprint-launcher" 2>/dev/null || true
chmod +x "$IMPRINT_HOME/bin/imprint"              2>/dev/null || true
chmod +x "$IMPRINT_HOME/bin/uv"                   2>/dev/null || true

mkdir -p /usr/local/bin
ln -sf "$IMPRINT_HOME/bin/imprint" /usr/local/bin/imprint

exit 0
