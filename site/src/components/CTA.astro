---
---

<section class="py-24">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <div class="grad-border rounded-3xl p-10 sm:p-14">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">
        Give your agent a <span class="grad-text">memory worth remembering</span>.
      </h2>
      <p class="mt-4 text-[color:var(--color-text-muted)] max-w-xl mx-auto">
        Apache 2.0. Self-updating. Uninstall with one command. Start on your laptop, sync to a VPS when you're ready.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/installation"
          class="inline-flex items-center gap-2 px-5 py-3 rounded-lg font-semibold bg-gradient-to-r from-violet-500 to-indigo-500 text-white hover:from-violet-400 hover:to-indigo-400 transition"
        >
          Install Imprint
        </a>
        <a
          href="https://github.com/alexandruleca/imprint-memory-layer"
          class="inline-flex items-center gap-2 px-5 py-3 rounded-lg border border-[color:var(--color-border)] hover:border-[color:var(--color-accent)] hover:text-white text-[color:var(--color-text-muted)] transition"
        >
          Star on GitHub ↗
        </a>
      </div>
    </div>
  </div>
</section>
