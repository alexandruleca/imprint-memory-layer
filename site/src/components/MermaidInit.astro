---
// Renders any fenced ```mermaid code block as a live diagram.
//
// Starlight/Shiki highlight `mermaid` code blocks as plain text (no such
// grammar by default), producing <pre><code class="language-mermaid">…</code></pre>.
// This script walks those on page load, swaps them with <div class="mermaid">
// nodes, then hands them to mermaid.js for rendering. Works for landing pages
// and Starlight docs alike.
---

<script is:inline>
  (async () => {
    const blocks = document.querySelectorAll('pre > code.language-mermaid, pre > code[data-language="mermaid"]');
    if (!blocks.length) return;

    // Replace each syntax-highlighted block with a raw container mermaid can
    // render into. textContent reassembles the original source even after
    // Shiki has wrapped tokens in spans.
    blocks.forEach((code) => {
      const pre = code.parentElement;
      if (!pre || pre.dataset.mermaidRendered === 'true') return;
      const container = document.createElement('div');
      container.className = 'mermaid';
      container.textContent = code.textContent || '';
      pre.replaceWith(container);
    });

    const mermaid = (await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')).default;
    mermaid.initialize({
      startOnLoad: false,
      theme: 'dark',
      securityLevel: 'loose',
      themeVariables: {
        background: '#15172a',
        primaryColor: '#1f2144',
        primaryTextColor: '#eef0ff',
        primaryBorderColor: '#6366f1',
        lineColor: '#a78bfa',
        secondaryColor: '#262845',
        tertiaryColor: '#0f1020',
        fontFamily: 'Inter, ui-sans-serif, system-ui, sans-serif',
      },
      flowchart: { htmlLabels: true, curve: 'basis' },
      sequence: { actorMargin: 40 },
    });
    await mermaid.run({ querySelector: 'div.mermaid' });
  })();
</script>

<style is:global>
  div.mermaid {
    background: var(--color-surface, #15172a);
    border: 1px solid var(--color-border, #262845);
    border-radius: 0.75rem;
    padding: 1rem;
    margin: 1rem 0;
    overflow-x: auto;
    text-align: center;
  }
  div.mermaid svg {
    max-width: 100%;
    height: auto;
  }
</style>
